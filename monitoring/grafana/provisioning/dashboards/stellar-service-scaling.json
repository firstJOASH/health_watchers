{
  "title": "Stellar Service Scaling",
  "uid": "stellar-service-scaling",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Payment Queue Depth",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "stellar_payment_queue_depth", "legendFormat": "Queue Depth" }
      ],
      "options": {
        "colorMode": "background",
        "thresholds": {
          "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 5 },
            { "color": "red", "value": 10 }
          ]
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Stellar Transactions/min",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "rate(stellar_transactions_total[1m]) * 60", "legendFormat": "tx/min" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Payment Queue Depth Over Time",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "stellar_payment_queue_depth", "legendFormat": "Queue Depth" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Stellar Service CPU Utilization",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{container=\"stellar-service\"}[5m]) * 100",
          "legendFormat": "CPU % {{pod}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Transaction Rate by Status",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(stellar_transactions_total[5m])",
          "legendFormat": "{{type}} / {{status}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Stellar Service Memory Usage",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "container_memory_working_set_bytes{container=\"stellar-service\"}",
          "legendFormat": "Memory {{pod}}"
        }
      ]
    }
  ]
}

{
  "title": "Horizon Endpoint Health",
  "uid": "horizon-endpoint-health",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Healthy Endpoints",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(horizon_endpoint_healthy)",
          "legendFormat": "Healthy"
        }
      ],
      "options": {
        "colorMode": "background",
        "thresholds": {
          "steps": [
            { "color": "red", "value": 0 },
            { "color": "yellow", "value": 1 },
            { "color": "green", "value": 2 }
          ]
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Open Circuit Breakers",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(horizon_circuit_breaker_open)",
          "legendFormat": "Open"
        }
      ],
      "options": {
        "colorMode": "background",
        "thresholds": {
          "steps": [
            { "color": "green", "value": 0 },
            { "color": "red", "value": 1 }
          ]
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Failovers (last 1h)",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "increase(horizon_failovers_total[1h])",
          "legendFormat": "Failovers"
        }
      ],
      "options": {
        "colorMode": "background",
        "thresholds": {
          "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 5 }
          ]
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Endpoint Health Status",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "horizon_endpoint_healthy",
          "legendFormat": "{{url}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Endpoint Response Latency (p95)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(horizon_endpoint_latency_seconds_bucket[5m]))",
          "legendFormat": "p95 {{url}}"
        },
        {
          "expr": "histogram_quantile(0.50, rate(horizon_endpoint_latency_seconds_bucket[5m]))",
          "legendFormat": "p50 {{url}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Circuit Breaker State",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "horizon_circuit_breaker_open",
          "legendFormat": "{{url}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Failover Rate",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "rate(horizon_failovers_total[5m])",
          "legendFormat": "{{from}} → {{to}}"
        }
      ]
    }
  ]
}
